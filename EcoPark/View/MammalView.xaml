<Window
    x:Class="EcoPark.View.MammalView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:EcoPark.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MammalView"
    Width="350"
    Height="400"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="0*" />
        </Grid.RowDefinitions>
        <Rectangle
            Width="306"
            Height="116"
            Margin="0,208,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Stroke="Black" />
        <Rectangle
            Width="306"
            Height="156"
            Margin="0,36,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Stroke="Black" />
        <TextBlock
            Width="136"
            Height="21"
            Margin="39,56,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            FontWeight="Bold"
            TextWrapping="Wrap"><Run Language="sv-se" Text="General Mammal Data" /></TextBlock>
        <TextBlock
            Width="95"
            Height="22"
            Margin="73,92,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            TextWrapping="Wrap"><Run Language="sv-se" Text="Number of legs" /></TextBlock>
        <TextBlock
            Width="66"
            Height="26"
            Margin="74,128,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            RenderTransformOrigin="0.5,0.5"
            TextWrapping="Wrap">
            <TextBlock.RenderTransform>
                <TransformGroup>
                    <ScaleTransform />
                    <SkewTransform AngleX="0.868" />
                    <RotateTransform />
                    <TranslateTransform X="0.318" />
                </TransformGroup>
            </TextBlock.RenderTransform><Run Text="Tail length " /><LineBreak /></TextBlock>
        <TextBox
            x:Name="txtNumOfLegs"
            Width="42"
            Height="22"
            Margin="164,88,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            TextWrapping="Wrap" />
        <TextBox
            x:Name="txtTailLength"
            Width="42"
            Height="21"
            Margin="143,124,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            TextWrapping="Wrap" />
        <TextBlock
            Width="23"
            Height="20"
            Margin="190,130,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            TextWrapping="Wrap"><Run Language="sv-se" Text="cm" /></TextBlock>
        <Button
            x:Name="btnOK"
            Width="66"
            Height="33"
            Margin="84,336,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="#FF56B32D"
            Click="btnOK_Click"
            Content="OK"
            FontWeight="Bold"
            IsDefault="True" />
        <Button
            x:Name="btnCancel"
            Width="68"
            Height="33"
            Margin="182,336,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="#FFFF1B1B"
            Click="btnCancel_Click"
            Content="Cancel"
            FontWeight="Bold"
            IsCancel="True" />
        <TextBlock
            x:Name="txtSpecificSpecies"
            Width="171"
            Height="24"
            Margin="38,222,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            FontWeight="Bold"
            TextWrapping="Wrap"><Run Language="sv-se" Text="x Specific Data" /></TextBlock>
        <TextBlock
            x:Name="txtblock1"
            Width="90"
            Height="33"
            Margin="60,256,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            TextWrapping="Wrap"><Run Text="TextBlock" /><Run Language="sv-se" Text="1" /></TextBlock>
        <TextBox
            x:Name="txtInputBlock1"
            Width="85"
            Height="20"
            Margin="159,256,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            TextWrapping="Wrap" />
        <TextBlock
            x:Name="txtblock2"
            Width="80"
            Height="18"
            Margin="60,294,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            TextWrapping="Wrap"><Run Text="TextBlock" /><Run Language="sv-se" Text="2" /></TextBlock>
        <CheckBox
            x:Name="chkInput"
            Width="51"
            Height="18"
            Margin="158,295,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Content="Yes" />
    </Grid>
</Window>
